# Database
DATABASE_URL="postgresql://user:password@localhost:5432/voxora_ai"
DIRECT_URL="postgresql://user:password@localhost:5432/voxora_ai"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_SECRET_KEY="your-secret-key"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4.1-mini"

# Twilio
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-token"
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_WEBHOOK_BASE_URL="http://localhost:3000"

# Razorpay
RAZORPAY_KEY_ID="rzp_..."
RAZORPAY_KEY_SECRET="your-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# App
APP_URL="http://localhost:3000"

# Demo Mode (Optional - for development/demo purposes)
# Set to "true" to enable demo mode without authentication
DEMO_MODE="true"

# Demo Business ID (Optional - used in demo mode)
# Defaults to "demo-voxora-ai" if not specified
DEMO_BUSINESS_ID="demo-voxora-ai"
